# Supabase 연동용 환경변수.
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요. (.env.local 은 git 미추적)
# 값은 Supabase 대시보드 → Project Settings → API 에서 복사.

# 프로젝트 URL (예: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public 키 (브라우저 노출 OK — RLS로 보호)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role 키 (서버 전용·절대 클라이언트 노출 금지 — 관리자 쓰기/추첨용)
SUPABASE_SERVICE_ROLE_KEY=

# 쿠팡 파트너스 Open API (추천딜 상품 검색·제휴링크)
# 쿠팡 파트너스 → 내정보 → 인증키 발급 (서버 전용)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# Resend (이후 단계)
RESEND_API_KEY=
RESEND_FROM="오늘의딜 <noreply@todaydeals.co.kr>"

# 관리자 페이지(/admin) 보호 — 이 둘을 설정하면 Basic Auth 적용
ADMIN_USER=
ADMIN_PASS=

# 크롤러(수집) — Cron 보호용 시크릿 (아무 긴 랜덤 문자열)
CRON_SECRET=

# 알리익스프레스 Affiliate API (승인 후 발급)
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=

# 링크프라이스 제휴 ID (G마켓·11번가·알리 딥링크 변환용 — 공개 링크에 노출되는 값)
LINKPRICE_AFFILIATE_ID=
# G마켓 프로모션(gmarket2, 2.59%) 승인되면 gmarket2 로 (기본 gmarket)
LINKPRICE_GMARKET_MERCHANT=gmarket

# 11번가 오픈 API (발급 시)
ELEVENST_API_KEY=

# Claude API (추천딜 한줄평 AI 자동생성 — 서버 전용). 없으면 템플릿 한줄평으로 폴백.
# console.anthropic.com → API Keys 에서 발급
ANTHROPIC_API_KEY=
